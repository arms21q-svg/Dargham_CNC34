generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SiteConfig {
  id             Int      @id @default(1)
  version        Int      @default(1)
  heroTitleAr      String
  heroTitleEn      String
  heroSubtitleAr   String
  heroSubtitleEn   String
  heroDescAr       String
  heroDescEn       String
  slideImages      String[]
  whatsapp         String
  facebook         String
  mapsUrl          String
  addressAr        String
  addressEn        String
  whatsappMsgAr    String
  whatsappMsgEn    String
  floatLinks       Json     @default("[]")
  about            Json     @default("{}")
  aiEnabled        Boolean  @default(true)
  aiWelcomeAr      String   @default("مرحباً! أنا مساعد ضرغام CNC. اسألني عن أعمالنا وخدماتنا.")
  aiWelcomeEn      String   @default("Hello! I am Dorgham CNC assistant. Ask about our works and services.")
  adminEmail       String
  adminPasswordHash String
  updatedAt        DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String
  nameAr       String   @default("")
  nameEn       String   @default("")
  role         String   @default("admin")
  /** Job title shown in employee management (e.g. محرر محتوى) */
  jobTitle     String   @default("")
  /** active | disabled */
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([role])
  @@index([status])
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  action       String
  actorEmail   String
  actorRole    String   @default("")
  targetUserId String?
  targetEmail  String?
  details      String   @default("")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

model Product {
  id            String   @id
  titleAr       String
  titleEn       String
  descriptionAr String
  descriptionEn String
  category      String
  image         String
  materialsAr   String
  materialsEn   String
  dimensionsAr  String
  dimensionsEn  String
  featured      Boolean  @default(false)
  colors        String[]
  sortOrder     Int      @default(0)
  /** 64-bit average-hash hex for near-exact visual match */
  imageHash     String?
  /** Compact RGB vector (12x12x3 = 432) mirrored to pgvector `embedding` via raw SQL */
  imageVector   Json?
  indexedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([featured, sortOrder])
  @@index([category, sortOrder])
  @@index([sortOrder])
  @@index([updatedAt])
  @@index([imageHash])
}

model Manager {
  id        String  @id @default(uuid())
  nameAr    String
  nameEn    String
  roleAr    String
  roleEn    String
  phone     String
  whatsapp  String?
  sortOrder Int     @default(0)

  @@index([sortOrder])
}
