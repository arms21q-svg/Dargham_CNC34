# Supabase PostgreSQL — من Settings → Database → Connection string
# Transaction pooler (للتطبيق)
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (للـ migrations)
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# مفتاح سري لتسجيل الدخول (إلزامي في الإنتاج — 24 حرفاً على الأقل، عشوائي)
JWT_SECRET="change-this-to-a-long-random-secret-min-24-chars"

# رابط API للواجهة عند النشر على دومين مختلف (اتركه فارغاً إن كان API على نفس الدومين)
# NEXT_PUBLIC_API_URL="https://www.dhirghamcnc.com"

# OpenAI — للمساعد الذكي (اختياري)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Google Gemini — للمساعد الذكي (مفضّل)
# GEMINI_API_KEY="AIza..."   ← مفتاح API فقط من Google AI Studio
# GEMINI_MODEL="gemini-2.0-flash"   ← اسم النموذج فقط (ليس المفتاح!) أمثلة: gemini-2.0-flash | gemini-2.5-flash
# GEMINI_EMBED_MODEL="text-embedding-004"
